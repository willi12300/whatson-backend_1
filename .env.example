# ─────────────────────────────────────────────────────────────
# WHAT'SON BACKEND — ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in your real values.
# On Railway, set these in the service "Variables" tab instead.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Locally (Docker):  postgresql://whatson:whatson_dev@localhost:5432/whatson
# On Railway: copy the DATABASE_URL from your Postgres service.
DATABASE_URL=postgresql://whatson:whatson_dev@localhost:5432/whatson

# Railway provides PORT automatically. Locally it defaults to 3000.
PORT=3000

# Environment
NODE_ENV=development

# ── API KEYS ──────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_key_here
FOURSQUARE_API_KEY=your_foursquare_service_key_here
SKIDDLE_API_KEY=your_skiddle_key_here
EVENTBRITE_TOKEN=your_eventbrite_private_token_here

# ── SECURITY ──────────────────────────────────────────────────
# A secret you choose — protects the /sync endpoints from random calls.
# Make it a long random string.
SYNC_SECRET=change_this_to_a_long_random_string
